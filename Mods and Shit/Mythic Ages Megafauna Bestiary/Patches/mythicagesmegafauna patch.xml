<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/RecipeDef[defName="MA_Prepare_SkyfeatherPipe"]/researchPrerequisite</xpath>
		<match Class="PatchOperationReplace">
			<xpath>/Defs/RecipeDef[defName="MA_Prepare_SkyfeatherPipe"]/researchPrerequisite</xpath>
			<value>
				<researchPrerequisite>Ferny_SkyfeatherPipe</researchPrerequisite>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/RecipeDef[defName="MA_Prepare_SkyfeatherPipe"]</xpath>
			<value>
				<researchPrerequisite>Ferny_SkyfeatherPipe</researchPrerequisite>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/RecipeDef[defName="MA_Make_MossmireDraught"]/researchPrerequisite</xpath>
		<match Class="PatchOperationReplace">
			<xpath>/Defs/RecipeDef[defName="MA_Make_MossmireDraught"]/researchPrerequisite</xpath>
			<value>
				<researchPrerequisite>Ferny_MossmireDraught</researchPrerequisite>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/RecipeDef[defName="MA_Make_MossmireDraught"]</xpath>
			<value>
				<researchPrerequisite>Ferny_MossmireDraught</researchPrerequisite>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/RecipeDef[defName="MA_Refine_SivaDustIvory"]/researchPrerequisite</xpath>
		<match Class="PatchOperationReplace">
			<xpath>/Defs/RecipeDef[defName="MA_Refine_SivaDustIvory"]/researchPrerequisite</xpath>
			<value>
				<researchPrerequisite>Ferny_SivaDustIvory</researchPrerequisite>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/RecipeDef[defName="MA_Refine_SivaDustIvory"]</xpath>
			<value>
				<researchPrerequisite>Ferny_SivaDustIvory</researchPrerequisite>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationReplace" MayRequire="dankpyon.medieval.overhaul">
		<xpath>/Defs/RecipeDef[defName="MA_Make_MossmireDraught"]/recipeUsers</xpath>
		<value>
			<recipeUsers>
				<li>DankPyon_AlchemyBench</li>
			</recipeUsers>
		</value>
	</Operation>

</Patch>
