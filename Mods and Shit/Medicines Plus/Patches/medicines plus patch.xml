<Patch>

<Operation Class="PatchOperationFindMod">
  <mods>
    <li>Vanilla Plants Expanded - Succulents</li>
  </mods>
  <match Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
    <value>
      <ReplaceLib.ReplacerDef>
        <defName>ProgDrugs_MedicinesPlus_VPESucculents</defName>
        <replacers>
          <li>
            <replace>VCE_Plant_PeyotePlant</replace>
            <with>PlantPeyote</with>
          </li>
        </replacers>
      </ReplaceLib.ReplacerDef>
    </value>
  </match>
</Operation>


<!-- OPIUM/POPPY OVERLAP PRIORITY
     Lowest: Vanilla Factions Expanded - Classical.
     Medium: Medieval Overhaul's poppy plant.
     Highest: Medicines+' opium product.
     Losing cultivated plants have sowTags removed so they stop appearing as grow-zone options. -->
<Operation Class="PatchOperationFindMod">
  <mods>
    <li>Vanilla Factions Expanded - Classical</li>
  </mods>
  <match Class="PatchOperationFindMod">
    <mods>
      <li>Medieval Overhaul</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>/Defs</xpath>
          <value>
            <ReplaceLib.ReplacerDef>
              <defName>ProgDrugs_MedicinesPlus_PoppyPriority_VFEC_MedievalOverhaul</defName>
              <replacers>
                <li>
                  <replace>VFEC_Opium</replace>
                  <with>PoppyLatex</with>
                </li>
                <li>
                  <replace>VFEC_PlantPoppy</replace>
                  <with>DankPyon_Plant_Poppy</with>
                </li>
                <li>
                  <replace>PlantPapaver</replace>
                  <with>DankPyon_Plant_Poppy</with>
                </li>
                <li>
                  <replace>DankPyon_Poppy</replace>
                  <with>PoppyLatex</with>
                </li>
              </replacers>
            </ReplaceLib.ReplacerDef>
          </value>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>/Defs/ThingDef[defName="VFEC_PlantPoppy"]/plant/sowTags</xpath>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>/Defs/ThingDef[defName="PlantPapaver"]/plant/sowTags</xpath>
        </li>
      </operations>
    </match>
    <nomatch Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>/Defs</xpath>
          <value>
            <ReplaceLib.ReplacerDef>
              <defName>ProgDrugs_MedicinesPlus_PoppyPriority_VFEC</defName>
              <replacers>
                <li>
                  <replace>VFEC_Opium</replace>
                  <with>PoppyLatex</with>
                </li>
                <li>
                  <replace>VFEC_PlantPoppy</replace>
                  <with>PlantPapaver</with>
                </li>
              </replacers>
            </ReplaceLib.ReplacerDef>
          </value>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>/Defs/ThingDef[defName="VFEC_PlantPoppy"]/plant/sowTags</xpath>
        </li>
      </operations>
    </nomatch>
  </match>
</Operation>

<Operation Class="PatchOperationFindMod">
  <mods>
    <li>Medieval Overhaul</li>
  </mods>
  <match Class="PatchOperationFindMod">
    <mods>
      <li>Vanilla Factions Expanded - Classical</li>
    </mods>
    <nomatch Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>/Defs</xpath>
          <value>
            <ReplaceLib.ReplacerDef>
              <defName>ProgDrugs_MedicinesPlus_PoppyPriority_MedievalOverhaul</defName>
              <replacers>
                <li>
                  <replace>PlantPapaver</replace>
                  <with>DankPyon_Plant_Poppy</with>
                </li>
                <li>
                  <replace>DankPyon_Poppy</replace>
                  <with>PoppyLatex</with>
                </li>
              </replacers>
            </ReplaceLib.ReplacerDef>
          </value>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>/Defs/ThingDef[defName="PlantPapaver"]/plant/sowTags</xpath>
        </li>
      </operations>
    </nomatch>
  </match>
</Operation>







