<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ResearchProjectDef[defName="AT_AddictionPharmacology"]/label</xpath>
    <value>
      <!-- Original: addiction pharmacology -->
      <label>basic addiction pharmacology</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ResearchProjectDef[defName="AT_AddictionPharmacology"]/description</xpath>
    <value>
      <!-- Original: Develop pharmaceutical compounds capable of satisfying neurochemical cravings without producing the harmful effects of the original addictive substance. Allows the production of targeted treatment pills for the most common addictions in the colony. -->
      <description>Develop pharmaceutical compounds capable of satisfying neurochemical cravings without producing the harmful effects of the original addictive substance. Allows the production of alcohol treatment pills.</description>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ResearchProjectDef[defName="AT_AddictionPharmacology"]/baseCost</xpath>
