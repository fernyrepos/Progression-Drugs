<?xml version="1.0" encoding="utf-8" ?>
<Patch>     

<Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="Flake"]/recipeMaker/researchPrerequisite</xpath>
    <value>
    <researchPrerequisite>Ferny_Flake</researchPrerequisite>
    </value>
</Operation>


<Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="SmokeleafJoint"]/recipeMaker/researchPrerequisite</xpath>
    <match Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="SmokeleafJoint"]/recipeMaker/researchPrerequisite</xpath>
        <value>
            <researchPrerequisite>Ferny_SmokeleafJoint</researchPrerequisite>
        </value>
    </match>
    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="SmokeleafJoint"]/recipeMaker</xpath>
        <value>
            <researchPrerequisite>Ferny_SmokeleafJoint</researchPrerequisite>
        </value>
    </nomatch>
</Operation>

</Patch>